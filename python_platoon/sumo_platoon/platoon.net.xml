<?xml version="1.0" encoding="UTF-8"?>
<!--
  guindy.net.xml
  Clean minimal network for platoon simulation:
  - Long main road: main_0 -> main_1 -> main_2 -> main_3
  - Two side roads: side1, side2 merge at main_1 and main_3
  - All lanes allow passenger vehicles only
-->
<nodes>
    <!-- main road nodes -->
    <node id="n0" x="0.0" y="0.0" type="priority"/>
    <node id="n1" x="1000.0" y="200.0" type="priority"/>
    <node id="n2" x="2200.0" y="800.0" type="priority"/>
    <node id="n3" x="3300.0" y="1800.0" type="priority"/>
    <node id="n4" x="4000.0" y="2600.0" type="priority"/>

    <!-- side roads -->
    <node id="s1a" x="800.0" y="600.0" type="priority"/>
    <node id="s1b" x="1000.0" y="400.0" type="priority"/>
    <node id="s2a" x="3100.0" y="2200.0" type="priority"/>
    <node id="s2b" x="3300.0" y="2000.0" type="priority"/>
</nodes>

<types>
    <type id="primary" numLanes="1" speed="13.89"/>
</types>

<edges>
    <!-- Main road -->
    <edge id="main_0" from="n0" to="n1" type="primary">
        <lane id="main_0_0" index="0" speed="13.89" allow="passenger" shape="0.0,0.0 1000.0,200.0"/>
    </edge>

    <edge id="main_1" from="n1" to="n2" type="primary">
        <lane id="main_1_0" index="0" speed="13.89" allow="passenger" shape="1000.0,200.0 2200.0,800.0"/>
    </edge>

    <edge id="main_2" from="n2" to="n3" type="primary">
        <lane id="main_2_0" index="0" speed="13.89" allow="passenger" shape="2200.0,800.0 3300.0,1800.0"/>
    </edge>

    <edge id="main_3" from="n3" to="n4" type="primary">
        <lane id="main_3_0" index="0" speed="13.89" allow="passenger" shape="3300.0,1800.0 4000.0,2600.0"/>
    </edge>

    <!-- Side roads merging into main -->
    <edge id="side1" from="s1a" to="s1b" type="primary">
        <lane id="side1_0" index="0" speed="11.11" allow="passenger" shape="800.0,600.0 1000.0,400.0"/>
    </edge>
    <edge id="side1_connector" from="s1b" to="n1" type="primary">
        <lane id="side1_conn_0" index="0" speed="11.11" allow="passenger" shape="1000.0,400.0 1000.0,200.0"/>
    </edge>

    <edge id="side2" from="s2a" to="s2b" type="primary">
        <lane id="side2_0" index="0" speed="11.11" allow="passenger" shape="3100.0,2200.0 3300.0,2000.0"/>
    </edge>
    <edge id="side2_connector" from="s2b" to="n3" type="primary">
        <lane id="side2_conn_0" index="0" speed="11.11" allow="passenger" shape="3300.0,2000.0 3300.0,1800.0"/>
    </edge>
</edges>
